    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zustand": "5.0.9"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "latest",
